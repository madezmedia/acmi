{
  "$schema": "https://smithery.ai/schemas/config.schema.json",
  "name": "@madezmedia/acmi-mcp",
  "version": "1.3.0",
  "description": "Persistent agent memory for any MCP host. 16 tools for profiles, signals, timeline events, work items, and multi-agent coordination on Upstash Redis.",
  "author": "Michael Shaw <madezmediapartners@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/madezmedia/acmi#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/madezmedia/acmi.git"
  },
  "bugs": "https://github.com/madezmedia/acmi/issues",
  "categories": [
    "Memory & Context",
    "Agent Coordination",
    "Data Persistence",
    "AI & Machine Learning",
    "Productivity"
  ],
  "tags": [
    "agent-memory",
    "multi-agent",
    "persistence",
    "state-management",
    "context-management",
    "redis",
    "upstash",
    "ai-agents",
    "fleet-management",
    "reinforcement-learning"
  ],
  "install": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@madezmedia/acmi-mcp"],
    "globalInstall": "npm install -g @madezmedia/acmi-mcp (optional — npx works without it)"
  },
  "configSchema": {
    "type": "object",
    "required": ["upstashRedisRestUrl", "upstashRedisRestToken"],
    "properties": {
      "upstashRedisRestUrl": {
        "type": "string",
        "title": "Upstash Redis REST URL",
        "description": "Upstash Redis REST endpoint URL (e.g. https://your-instance.upstash.io). Sign up free at upstash.com.",
        "x-from": {
          "env": "UPSTASH_REDIS_REST_URL"
        }
      },
      "upstashRedisRestToken": {
        "type": "string",
        "title": "Upstash Redis REST Token",
        "description": "Upstash Redis REST API token — keep this secret.",
        "x-from": {
          "env": "UPSTASH_REDIS_REST_TOKEN"
        }
      }
    }
  },
  "features": {
    "tools": {
      "count": 16,
      "list": [
        "acmi_profile",
        "acmi_signal",
        "acmi_event",
        "acmi_get",
        "acmi_list",
        "acmi_work_create",
        "acmi_work_event",
        "acmi_work_signal",
        "acmi_work_get",
        "acmi_work_list",
        "acmi_cat",
        "acmi_spawn",
        "acmi_bootstrap",
        "acmi_active",
        "acmi_rollup_set",
        "acmi_delete"
      ]
    }
  },
  "env": {
    "UPSTASH_REDIS_REST_URL": {
      "description": "Upstash Redis REST endpoint URL",
      "required": true
    },
    "UPSTASH_REDIS_REST_TOKEN": {
      "description": "Upstash Redis REST API token",
      "required": true,
      "secret": true
    }
  },
  "exampleConfig": {
    "upstashRedisRestUrl": "https://up-your-instance.upstash.io",
    "upstashRedisRestToken": "AYV-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  }
}
